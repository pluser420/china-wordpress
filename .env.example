# ============================================================
# Jiayi Tools Website — Environment Variables Example
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to version control.
# ============================================================

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
# Strong, randomly generated password for the Strapi DB user.
POSTGRES_PASSWORD=change_me_strong_password

# ------------------------------------------------------------
# Strapi
# ------------------------------------------------------------
# APP_KEYS: comma-separated list of 4 random base64 strings
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
STRAPI_APP_KEYS=key1_base64,key2_base64,key3_base64,key4_base64

# Salt used for API token hashing (random 32-byte hex string)
STRAPI_API_TOKEN_SALT=change_me_random_hex_salt

# Secret used to sign admin JWTs (random 32-byte hex string)
STRAPI_ADMIN_JWT_SECRET=change_me_admin_jwt_secret

# Secret used to sign user JWTs (random 32-byte hex string)
STRAPI_JWT_SECRET=change_me_jwt_secret

# ------------------------------------------------------------
# Next.js ↔ Strapi
# ------------------------------------------------------------
# Long-lived Strapi API token created in the Strapi admin panel
# (Settings → API Tokens → Create new token, Full Access or custom read permissions)
STRAPI_API_TOKEN=change_me_strapi_api_token

# Shared secret for the /api/revalidate webhook endpoint.
# Must match the value configured in Strapi webhook headers.
REVALIDATE_SECRET=change_me_revalidate_secret

# ------------------------------------------------------------
# Google reCAPTCHA v3
# ------------------------------------------------------------
# Public site key (safe to expose in the browser)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Private secret key (server-side only — never expose to browser)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ------------------------------------------------------------
# SMTP / Email delivery
# ------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password

# Email address that will receive all inquiry form submissions
INQUIRY_RECIPIENT=sales@jiayitools.com
